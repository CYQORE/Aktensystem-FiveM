// ============================================================
// S6mdt — Datenmodell (MySQL/MariaDB für FiveM-Server-DB)
//  - Provider MySQL: läuft auf der bestehenden ESX/oxmysql-DB.
//  - Alle Tabellen mit Prefix `s6mdt_` (@@map) -> keine Kollision mit
//    ESX-Tabellen (users, owned_vehicles, licenses, jobs ...).
//  - IDs als CHAR(36)-UUID (app-seitig via uuid() erzeugt).
//  - Langtext-Felder als TEXT; Scalar-Arrays gibt es in MySQL nicht ->
//    Listen als JSON. Enums als MySQL-ENUM-Spalten.
//  - Actor-Referenzen (officer/judge/author …) als denormalisierte UUIDs ohne FK.
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================
//  ENUMS
// ============================================================

enum SecurityLevel {
  INTERN
  VERTRAULICH
  BEHOERDENINTERN
  GEHEIM
  HOCHGEHEIM
}

enum CaseFileType {
  PERSONENAKTE
  ERMITTLUNGSAKTE
  STRAFAKTE
  FORENSIKAKTE
  OBDUKTIONSBERICHT
  PATIENTENAKTE
  GERICHTSAKTE
  STAATSANWALTSCHAFTSAKTE
  GEFAENGNISAKTE
  UNTERNEHMENSAKTE
  VERWALTUNGSAKTE
}

enum CaseFileStatus {
  ENTWURF
  OFFEN
  IN_BEARBEITUNG
  GESCHLOSSEN
  ARCHIVIERT
}

enum ShareStatus {
  PRIVAT
  BEANTRAGT
  IN_PRUEFUNG
  TEILFREIGEGEBEN
  VOLLSTAENDIG_FREIGEGEBEN
  ABGELEHNT
  WIDERRUFEN
}

enum ShareTargetType {
  PERSON
  ROLLE
  ABTEILUNG
  FRAKTION
  BEHOERDE
}

enum EmergencyLine {
  POLICE_911
  NON_EMERGENCY_311
  EMS_112
  BEHOERDENTELEFON
}

enum DispatchPriority {
  P1
  P2
  P3
  P4
}

enum DispatchStatus {
  OFFEN
  DISPATCHED
  UNTERWEGS
  VOR_ORT
  TRANSPORT
  ABGESCHLOSSEN
}

enum UnitStatus {
  FREI
  STREIFE
  VERKEHRSKONTROLLE
  EINSATZ
  VERFOLGUNG
  KRANKENHAUS
  PAUSE
  AUSSER_DIENST
}

enum ShiftType {
  FRUEH
  SPAET
  NACHT
  SONDERDIENST
}

enum AuditAction {
  CREATE
  READ
  UPDATE
  DELETE
  SHARE
  REVOKE
  LOGIN
  LOGOUT
  EXPORT
  SIGN
}

enum FactionKind {
  POLICE
  SHERIFF
  STATE_POLICE
  FEDERAL
  DOJ
  COURT
  DA_OFFICE
  CORRECTIONS
  PRISON
  EMS
  FIRE
  DISPATCH
  GOVERNMENT
  FORENSICS
  DMV
  CUSTOMS
  BUSINESS
  OTHER
}

enum OffenseClass {
  INFRACTION
  MISDEMEANOR
  FELONY
}

enum ChargeStatus {
  PENDING
  FILED
  CONVICTED
  DISMISSED
  DROPPED
}

enum WarrantType {
  ARREST
  SEARCH
  BENCH
}

enum WarrantStatus {
  ACTIVE
  EXECUTED
  EXPIRED
  RECALLED
}

enum FineStatus {
  UNPAID
  PAID
  CONTESTED
  WAIVED
}

enum CourtCaseType {
  CRIMINAL
  CIVIL
  TRAFFIC
  APPEAL
}

enum CourtCaseStatus {
  FILED
  SCHEDULED
  IN_TRIAL
  ADJOURNED
  CLOSED
  DISMISSED
}

enum HearingType {
  ARRAIGNMENT
  PRELIMINARY
  TRIAL
  SENTENCING
  APPEAL
}

enum VerdictType {
  GUILTY
  NOT_GUILTY
  DISMISSED
  MISTRIAL
  PLEA
}

enum SentenceType {
  PRISON
  FINE
  PROBATION
  COMMUNITY_SERVICE
  DEATH
}

enum InmateStatus {
  BOOKED
  INCARCERATED
  PAROLE
  RELEASED
  TRANSFERRED
}

// Outbound-Befehle an die FiveM-Lua-Bridge (Geld/Haft laufen NUR in-game).
enum FivemCommandType {
  FINE // Geld in-game einziehen
  JAIL // Spieler in-game einsperren
  RELEASE // Spieler in-game freilassen
}

enum FivemCommandStatus {
  PENDING // angelegt, noch nicht an Lua ausgeliefert
  DELIVERED // an Lua ausgeliefert, Ausführung läuft
  DONE // in-game erfolgreich ausgeführt
  FAILED // Ausführung fehlgeschlagen (z. B. zu wenig Geld)
}

enum LicenseType {
  DRIVER
  WEAPON
  BUSINESS
  PILOT
  HUNTING
  MEDICAL
  LAW
}

enum LicenseStatus {
  ACTIVE
  SUSPENDED
  REVOKED
  EXPIRED
}

enum CustomsStatus {
  DECLARED
  CLEARED
  SEIZED
}

enum BusinessType {
  GENERAL
  RESTAURANT
  REAL_ESTATE
  MECHANIC
  SECURITY
  NEWS
  OTHER
}

enum EmploymentStatus {
  ACTIVE
  SUSPENDED
  TERMINATED
}

enum ListingStatus {
  AVAILABLE
  RESERVED
  SOLD
}

enum JobStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum LeaveType {
  VACATION
  SICK
  OTHER
}

enum LeaveStatus {
  REQUESTED
  APPROVED
  REJECTED
}

enum WorkflowStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
}

enum NotificationType {
  INFO
  WARNING
  SHARE_REQUEST
  ASSIGNMENT
  ALERT
}

enum AuthTicketSource {
  NUI
  BROWSER
}

// ============================================================
//  IDENTITY / AUTH
// ============================================================

model User {
  id              String        @id @default(uuid()) @db.Char(36)
  discordId       String?       @unique
  username        String
  globalName      String?
  avatar          String?       @db.Text
  email           String?
  clearance       SecurityLevel @default(INTERN)
  isPlatformAdmin Boolean       @default(false)
  fivemIdentifier String?       @unique
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  lastLoginAt     DateTime?

  memberships      FactionMembership[]
  refreshTokens    RefreshToken[]
  createdCaseFiles CaseFile[]          @relation("CaseFileCreator")
  auditLogs        AuditLog[]
  shiftLogs        ShiftLog[]
  signatures       Signature[]
  notifications    Notification[]
  settings         UserSettings?

  @@index([fivemIdentifier])
  @@map("s6mdt_user")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Char(36)
  userId    String    @db.Char(36)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?   @db.Text
  ip        String?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("s6mdt_refresh_token")
}

model PlatformBootstrap {
  id        String   @id @default(uuid()) @db.Char(36)
  key       String   @unique
  userId    String   @db.Char(36)
  claimedAt DateTime @default(now())

  @@map("s6mdt_platform_bootstrap")
}

model PlatformModule {
  id          String   @id @default(uuid()) @db.Char(36)
  key         String   @unique
  name        String
  description String?  @db.Text
  icon        String?
  route       String?
  category    String?
  enabled     Boolean  @default(true)
  core        Boolean  @default(false)
  sortOrder   Int      @default(100)
  version     String   @default("1.0.0")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("s6mdt_platform_module")
}

model AuthTicket {
  id        String           @id @default(uuid()) @db.Char(36)
  code      String           @unique
  userId    String           @db.Char(36)
  source    AuthTicketSource @default(NUI)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([expiresAt])
  @@map("s6mdt_auth_ticket")
}

// ============================================================
//  FRAKTIONEN / RBAC
// ============================================================

model Faction {
  id        String      @id @default(uuid()) @db.Char(36)
  kind      FactionKind
  name      String
  shortName String      @unique
  color     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  departments    Department[]
  ranks          Rank[]
  memberships    FactionMembership[]
  ownedCaseFiles CaseFile[]          @relation("CaseFileOwnerFaction")
  units          Unit[]
  shiftSchedules ShiftSchedule[]
  issuedLicenses License[]

  @@index([kind])
  @@map("s6mdt_faction")
}

model Department {
  id        String   @id @default(uuid()) @db.Char(36)
  factionId String   @db.Char(36)
  faction   Faction  @relation(fields: [factionId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime @default(now())

  memberships FactionMembership[]

  @@unique([factionId, name])
  @@map("s6mdt_department")
}

model Rank {
  id        String        @id @default(uuid()) @db.Char(36)
  factionId String        @db.Char(36)
  faction   Faction       @relation(fields: [factionId], references: [id], onDelete: Cascade)
  name      String
  level     Int
  shareTier Int           @default(0)
  clearance SecurityLevel @default(INTERN)
  grants    Json? // zusätzliche Rechte: [{ action, subject }] — pro Rang konfigurierbar

  memberships FactionMembership[]

  @@unique([factionId, name])
  @@index([factionId, level])
  @@map("s6mdt_rank")
}

model FactionMembership {
  id           String      @id @default(uuid()) @db.Char(36)
  userId       String      @db.Char(36)
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  factionId    String      @db.Char(36)
  faction      Faction     @relation(fields: [factionId], references: [id], onDelete: Cascade)
  rankId       String?     @db.Char(36)
  rank         Rank?       @relation(fields: [rankId], references: [id])
  departmentId String?     @db.Char(36)
  department   Department? @relation(fields: [departmentId], references: [id])
  callsign     String?
  isActive     Boolean     @default(true)
  joinedAt     DateTime    @default(now())
  extraGrants  Json?

  @@unique([userId, factionId])
  @@index([factionId])
  @@map("s6mdt_faction_membership")
}

// ============================================================
//  REGISTER: Bürger / Fahrzeug / Immobilie
// ============================================================

model Citizen {
  id          String    @id @default(uuid()) @db.Char(36)
  firstName   String
  lastName    String
  dateOfBirth DateTime?
  gender      String?
  fivemCharId String?   @unique
  phone       String?
  address     String?   @db.Text
  photo       String?   @db.MediumText // Data-URL (Upload) bis ~3 MB, daher MEDIUMTEXT
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  vehicles            Vehicle[]
  properties          Property[]
  caseFiles           CaseFile[]           @relation("CaseFileSubject")
  patientRecords      PatientRecord[]
  licenses            License[]
  charges             Charge[]
  arrests             ArrestRecord[]
  fines               Fine[]
  warrants            Warrant[]
  employments         BusinessEmployee[]
  ownedBusinesses     Business[]           @relation("BusinessOwner")
  inmateRecords       Inmate[]
  courtCasesDefendant CourtCase[]          @relation("CourtCaseDefendant")
  medicalIncidents    MedicalIncident[]
  customsDeclarations CustomsDeclaration[]
  tags                CitizenTag[]

  @@index([lastName, firstName])
  @@index([fivemCharId])
  @@map("s6mdt_citizen")
}

model Vehicle {
  id        String   @id @default(uuid()) @db.Char(36)
  plate     String   @unique
  model     String?
  color     String?
  ownerId   String?  @db.Char(36)
  owner     Citizen? @relation(fields: [ownerId], references: [id])
  stolen    Boolean  @default(false)
  impounded Boolean  @default(false)
  createdAt DateTime @default(now())

  registration VehicleRegistration?
  insurance    Insurance?
  mechanicJobs MechanicJob[]
  activities   VehicleActivity[]

  @@index([ownerId])
  @@map("s6mdt_vehicle")
}

// Aktivitäts-Log am Fahrzeug (Kontrollen/Scans/Beschlagnahme) — wie nn_mdt.
model VehicleActivity {
  id           String   @id @default(uuid()) @db.Char(36)
  vehicleId    String   @db.Char(36)
  vehicle      Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  activityType String // Verkehrskontrolle | Papierkontrolle | Kennzeichen-Scan | Beschlagnahme | Sonstiges
  location     String?  @db.Text
  notes        String?  @db.Text
  byUserId     String   @db.Char(36)
  createdAt    DateTime @default(now())

  @@index([vehicleId, createdAt])
  @@map("s6mdt_vehicle_activity")
}

model VehicleRegistration {
  id           String    @id @default(uuid()) @db.Char(36)
  vehicleId    String    @unique @db.Char(36)
  vehicle      Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  registeredTo String?
  validUntil   DateTime?
  issuedAt     DateTime  @default(now())

  @@map("s6mdt_vehicle_registration")
}

model Insurance {
  id         String    @id @default(uuid()) @db.Char(36)
  vehicleId  String    @unique @db.Char(36)
  vehicle    Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  provider   String
  policyNo   String
  validUntil DateTime?

  @@map("s6mdt_insurance")
}

model Property {
  id        String   @id @default(uuid()) @db.Char(36)
  label     String
  address   String   @db.Text
  ownerId   String?  @db.Char(36)
  owner     Citizen? @relation(fields: [ownerId], references: [id])
  createdAt DateTime @default(now())

  listings RealEstateListing[]

  @@index([ownerId])
  @@map("s6mdt_property")
}

// ============================================================
//  AKTENSYSTEM (polymorphe Basis)
// ============================================================

model CaseFile {
  id                String         @id @default(uuid()) @db.Char(36)
  type              CaseFileType
  title             String         @db.Text
  summary           String?        @db.Text
  status            CaseFileStatus @default(ENTWURF)
  securityLevel     SecurityLevel  @default(INTERN)
  securityLevelRank Int            @default(1)
  shareStatus       ShareStatus    @default(PRIVAT)

  ownerFactionId String  @db.Char(36)
  ownerFaction   Faction @relation("CaseFileOwnerFaction", fields: [ownerFactionId], references: [id])
  creatorId      String  @db.Char(36)
  creator        User    @relation("CaseFileCreator", fields: [creatorId], references: [id])

  subjectCitizenId String?  @db.Char(36)
  subjectCitizen   Citizen? @relation("CaseFileSubject", fields: [subjectCitizenId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  forensicDetail ForensicDetail?
  patientRecord  PatientRecord?

  shares        FileShare[]
  documents     Document[]
  signatures    Signature[]
  evidenceItems EvidenceItem[]
  charges       Charge[]
  arrests       ArrestRecord[]
  warrants      Warrant[]
  courtCases    CourtCase[]
  inmateRecords Inmate[]
  workflows     WorkflowInstance[]

  linksFrom CaseFileLink[] @relation("LinkSource")
  linksTo   CaseFileLink[] @relation("LinkTarget")

  @@index([ownerFactionId, type])
  @@index([securityLevelRank])
  @@index([subjectCitizenId])
  @@map("s6mdt_case_file")
}

model CaseFileLink {
  id        String   @id @default(uuid()) @db.Char(36)
  sourceId  String   @db.Char(36)
  source    CaseFile @relation("LinkSource", fields: [sourceId], references: [id], onDelete: Cascade)
  targetId  String   @db.Char(36)
  target    CaseFile @relation("LinkTarget", fields: [targetId], references: [id], onDelete: Cascade)
  relation  String?
  createdAt DateTime @default(now())

  @@unique([sourceId, targetId])
  @@map("s6mdt_case_file_link")
}

model FileShare {
  id            String          @id @default(uuid()) @db.Char(36)
  caseFileId    String          @db.Char(36)
  caseFile      CaseFile        @relation(fields: [caseFileId], references: [id], onDelete: Cascade)
  targetType    ShareTargetType
  targetId      String
  status        ShareStatus     @default(BEANTRAGT)
  reason        String?         @db.Text
  // Feld-Whitelist für Teilfreigaben (MySQL kennt keine Scalar-Arrays -> JSON)
  allowedFields Json?
  requestedById String          @db.Char(36)
  decidedById   String?         @db.Char(36)
  decidedAt     DateTime?
  expiresAt     DateTime?
  createdAt     DateTime        @default(now())

  @@index([caseFileId])
  @@index([targetType, targetId])
  @@map("s6mdt_file_share")
}

// ============================================================
//  FORENSIK + Chain of Custody
// ============================================================

model ForensicDetail {
  id           String   @id @default(uuid()) @db.Char(36)
  caseFileId   String   @unique @db.Char(36)
  caseFile     CaseFile @relation(fields: [caseFileId], references: [id], onDelete: Cascade)
  dna          Json?
  fingerprints Json?
  ballistics   Json?
  toxicology   Json?
  autopsy      Json?
  createdAt    DateTime @default(now())

  @@map("s6mdt_forensic_detail")
}

model EvidenceItem {
  id         String   @id @default(uuid()) @db.Char(36)
  caseFileId String   @db.Char(36)
  caseFile   CaseFile @relation(fields: [caseFileId], references: [id], onDelete: Cascade)
  label      String
  kind       String
  storageRef String?  @db.Text
  createdAt  DateTime @default(now())

  custody CustodyEvent[]

  @@index([caseFileId])
  @@map("s6mdt_evidence_item")
}

model CustodyEvent {
  id         String       @id @default(uuid()) @db.Char(36)
  evidenceId String       @db.Char(36)
  evidence   EvidenceItem @relation(fields: [evidenceId], references: [id], onDelete: Cascade)
  action     String
  byUserId   String       @db.Char(36)
  location   String?      @db.Text
  note       String?      @db.Text
  at         DateTime     @default(now())

  @@index([evidenceId, at])
  @@map("s6mdt_custody_event")
}

// ============================================================
//  MEDICAL (EMS Datenschutz) + Fire
// ============================================================

model PatientRecord {
  id           String   @id @default(uuid()) @db.Char(36)
  caseFileId   String   @unique @db.Char(36)
  caseFile     CaseFile @relation(fields: [caseFileId], references: [id], onDelete: Cascade)
  citizenId    String?  @db.Char(36)
  citizen      Citizen? @relation(fields: [citizenId], references: [id])
  publicStatus String   @default("STATUS")
  diagnoses    Json?
  medications  Json?
  psychNotes   Json?
  createdAt    DateTime @default(now())

  @@map("s6mdt_patient_record")
}

model MedicalIncident {
  id        String   @id @default(uuid()) @db.Char(36)
  citizenId String?  @db.Char(36)
  citizen   Citizen? @relation(fields: [citizenId], references: [id])
  emsUserId String?  @db.Char(36)
  type      String
  location  String?  @db.Text
  outcome   String?  @db.Text
  at        DateTime @default(now())

  @@index([citizenId])
  @@map("s6mdt_medical_incident")
}

model FireIncident {
  id               String   @id @default(uuid()) @db.Char(36)
  type             String
  location         String   @db.Text
  severity         Int      @default(1)
  reportCaseFileId String?  @db.Char(36)
  at               DateTime @default(now())

  @@map("s6mdt_fire_incident")
}

// ============================================================
//  JUSTICE: Gesetze, Anklagen, Fahndung, Gericht, Strafen
// ============================================================

model PenalCode {
  id          String       @id @default(uuid()) @db.Char(36)
  code        String       @unique
  title       String
  class       OffenseClass
  // nn_mdt-Gruppierung: Verkehr/Vergehen/Verbrechen/Waffen/Drogen/Behörde
  category    String       @default("Vergehen")
  description String?      @db.Text
  fineMin     Int          @default(0)
  fineMax     Int          @default(0)
  jailDaysMin Int          @default(0)
  jailDaysMax Int          @default(0)
  points      Int          @default(0) // Führerschein-Punkte (v.a. Verkehr)
  active      Boolean      @default(true)
  deletedAt   DateTime? // Soft-Delete (bricht keine Charge/Fine-FKs)

  charges Charge[]
  fines   Fine[]

  @@map("s6mdt_penal_code")
}

model Charge {
  id          String       @id @default(uuid()) @db.Char(36)
  caseFileId  String?      @db.Char(36)
  caseFile    CaseFile?    @relation(fields: [caseFileId], references: [id])
  citizenId   String       @db.Char(36)
  citizen     Citizen      @relation(fields: [citizenId], references: [id])
  penalCodeId String       @db.Char(36)
  penalCode   PenalCode    @relation(fields: [penalCodeId], references: [id])
  status      ChargeStatus @default(PENDING)
  count       Int          @default(1)
  notes       String?      @db.Text
  byUserId    String?      @db.Char(36)
  createdAt   DateTime     @default(now())

  @@index([citizenId])
  @@index([caseFileId])
  @@map("s6mdt_charge")
}

model Warrant {
  id         String        @id @default(uuid()) @db.Char(36)
  citizenId  String        @db.Char(36)
  citizen    Citizen       @relation(fields: [citizenId], references: [id])
  caseFileId String?       @db.Char(36)
  caseFile   CaseFile?     @relation(fields: [caseFileId], references: [id])
  title      String?
  priority   String        @default("MEDIUM") // LOW | MEDIUM | HIGH
  type       WarrantType   @default(ARREST)
  status     WarrantStatus @default(ACTIVE)
  reason     String        @db.Text
  issuedById String?       @db.Char(36)
  issuedAt   DateTime      @default(now())
  expiresAt  DateTime?

  @@index([citizenId, status])
  @@index([status])
  @@map("s6mdt_warrant")
}

model Bolo {
  id          String   @id @default(uuid()) @db.Char(36)
  title       String
  description String   @db.Text
  citizenId   String?  @db.Char(36)
  plate       String?
  active      Boolean  @default(true)
  byUserId    String?  @db.Char(36)
  createdAt   DateTime @default(now())

  @@index([active])
  @@map("s6mdt_bolo")
}

model ArrestRecord {
  id         String    @id @default(uuid()) @db.Char(36)
  citizenId  String    @db.Char(36)
  citizen    Citizen   @relation(fields: [citizenId], references: [id])
  caseFileId String?   @db.Char(36)
  caseFile   CaseFile? @relation(fields: [caseFileId], references: [id])
  officerId  String    @db.Char(36)
  location   String?   @db.Text
  notes      String?   @db.Text
  at         DateTime  @default(now())

  @@index([citizenId])
  @@map("s6mdt_arrest_record")
}

model Fine {
  id          String     @id @default(uuid()) @db.Char(36)
  citizenId   String     @db.Char(36)
  citizen     Citizen    @relation(fields: [citizenId], references: [id])
  penalCodeId String?    @db.Char(36)
  penalCode   PenalCode? @relation(fields: [penalCodeId], references: [id])
  amount      Int
  status      FineStatus @default(UNPAID)
  officerId   String?    @db.Char(36)
  issuedAt    DateTime   @default(now())
  paidAt      DateTime?

  @@index([citizenId, status])
  @@map("s6mdt_fine")
}

model CourtCase {
  id           String          @id @default(uuid()) @db.Char(36)
  number       Int             @unique @default(autoincrement())
  type         CourtCaseType   @default(CRIMINAL)
  status       CourtCaseStatus @default(FILED)
  title        String          @db.Text
  caseFileId   String?         @db.Char(36)
  caseFile     CaseFile?       @relation(fields: [caseFileId], references: [id])
  defendantId  String?         @db.Char(36)
  defendant    Citizen?        @relation("CourtCaseDefendant", fields: [defendantId], references: [id])
  prosecutorId String?         @db.Char(36)
  defenseId    String?         @db.Char(36)
  judgeId      String?         @db.Char(36)
  filedAt      DateTime        @default(now())
  closedAt     DateTime?

  hearings  CourtHearing[]
  verdicts  Verdict[]
  sentences Sentence[]

  @@index([status])
  @@map("s6mdt_court_case")
}

model CourtHearing {
  id          String      @id @default(uuid()) @db.Char(36)
  courtCaseId String      @db.Char(36)
  courtCase   CourtCase   @relation(fields: [courtCaseId], references: [id], onDelete: Cascade)
  type        HearingType
  scheduledAt DateTime
  room        String?
  notes       String?     @db.Text

  @@index([courtCaseId, scheduledAt])
  @@map("s6mdt_court_hearing")
}

model Verdict {
  id          String      @id @default(uuid()) @db.Char(36)
  courtCaseId String      @db.Char(36)
  courtCase   CourtCase   @relation(fields: [courtCaseId], references: [id], onDelete: Cascade)
  type        VerdictType
  summary     String?     @db.Text
  judgeId     String?     @db.Char(36)
  decidedAt   DateTime    @default(now())

  sentences Sentence[]

  @@index([courtCaseId])
  @@map("s6mdt_verdict")
}

model Sentence {
  id             String       @id @default(uuid()) @db.Char(36)
  courtCaseId    String       @db.Char(36)
  courtCase      CourtCase    @relation(fields: [courtCaseId], references: [id], onDelete: Cascade)
  verdictId      String?      @db.Char(36)
  verdict        Verdict?     @relation(fields: [verdictId], references: [id])
  type           SentenceType
  jailDays       Int?
  fineAmount     Int?
  probationDays  Int?
  communityHours Int?
  createdAt      DateTime     @default(now())

  inmate Inmate?

  @@index([courtCaseId])
  @@map("s6mdt_sentence")
}

// ============================================================
//  CORRECTIONS / PRISON
// ============================================================

model Inmate {
  id            String       @id @default(uuid()) @db.Char(36)
  bookingNumber Int          @unique @default(autoincrement())
  citizenId     String       @db.Char(36)
  citizen       Citizen      @relation(fields: [citizenId], references: [id])
  caseFileId    String?      @db.Char(36)
  caseFile      CaseFile?    @relation(fields: [caseFileId], references: [id])
  sentenceId    String?      @unique @db.Char(36)
  sentence      Sentence?    @relation(fields: [sentenceId], references: [id])
  status        InmateStatus @default(BOOKED)
  cell          String?
  propertyHeld  Json?
  jailSeconds   Int? // Haftdauer in Sekunden (für In-Game-Jail)
  reason        String?      @db.Text
  officerId     String?      @db.Char(36) // wer eingewiesen hat
  intakeAt      DateTime     @default(now())
  releaseAt     DateTime? // geplantes Entlassungsdatum
  servedAt      DateTime? // tatsächlich entlassen / abgesessen

  @@index([citizenId, status])
  @@map("s6mdt_inmate")
}

// Befehls-Warteschlange zur FiveM-Bridge. Web schreibt PENDING,
// Lua pollt für online Spieler, führt aus und quittiert (ack).
model FivemCommand {
  id               String             @id @default(uuid()) @db.Char(36)
  type             FivemCommandType
  status           FivemCommandStatus @default(PENDING)
  targetIdentifier String // ESX/FiveM-Identifier des Ziel-Spielers (= Citizen.fivemCharId)
  citizenId        String?            @db.Char(36)
  fineId           String?            @db.Char(36)
  inmateId         String?            @db.Char(36)
  amount           Int? // Geldbetrag (FINE)
  jailSeconds      Int? // Haftdauer in Sekunden (JAIL)
  reason           String?            @db.Text
  error            String?            @db.Text // Fehlermeldung bei FAILED
  claimId          String?            @db.Char(36) // atomares Batch-Token je Poll (verhindert Doppel-Auslieferung)
  createdAt        DateTime           @default(now())
  deliveredAt      DateTime?
  completedAt      DateTime?

  @@index([targetIdentifier, status])
  @@index([status])
  @@index([claimId])
  @@map("s6mdt_fivem_command")
}

// ============================================================
//  GOVERNMENT / DMV / CUSTOMS
// ============================================================

model License {
  id                String        @id @default(uuid()) @db.Char(36)
  type              LicenseType
  number            String        @unique
  status            LicenseStatus @default(ACTIVE)
  citizenId         String        @db.Char(36)
  citizen           Citizen       @relation(fields: [citizenId], references: [id])
  issuedByFactionId String?       @db.Char(36)
  issuedByFaction   Faction?      @relation(fields: [issuedByFactionId], references: [id])
  issuedAt          DateTime      @default(now())
  expiresAt         DateTime?

  @@index([citizenId, type])
  @@map("s6mdt_license")
}

model GovLaw {
  id        String   @id @default(uuid()) @db.Char(36)
  code      String   @unique
  title     String
  category  String?
  body      String   @db.Text
  effective DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("s6mdt_gov_law")
}

model CustomsDeclaration {
  id            String        @id @default(uuid()) @db.Char(36)
  declarantId   String?       @db.Char(36)
  declarant     Citizen?      @relation(fields: [declarantId], references: [id])
  goods         Json
  declaredValue Int           @default(0)
  status        CustomsStatus @default(DECLARED)
  inspectorId   String?       @db.Char(36)
  at            DateTime      @default(now())

  @@index([status])
  @@map("s6mdt_customs_declaration")
}

// ============================================================
//  BUSINESS
// ============================================================

model Business {
  id        String       @id @default(uuid()) @db.Char(36)
  name      String
  type      BusinessType @default(GENERAL)
  ownerId   String?      @db.Char(36)
  owner     Citizen?     @relation("BusinessOwner", fields: [ownerId], references: [id])
  address   String?      @db.Text
  balance   Int          @default(0)
  createdAt DateTime     @default(now())

  employees         BusinessEmployee[]
  menuItems         MenuItem[]
  listings          RealEstateListing[]
  mechanicJobs      MechanicJob[]
  securityContracts SecurityContract[]
  newsArticles      NewsArticle[]

  @@index([type])
  @@map("s6mdt_business")
}

model BusinessEmployee {
  id         String           @id @default(uuid()) @db.Char(36)
  businessId String           @db.Char(36)
  business   Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  citizenId  String           @db.Char(36)
  citizen    Citizen          @relation(fields: [citizenId], references: [id])
  role       String?
  wage       Int              @default(0)
  status     EmploymentStatus @default(ACTIVE)
  hiredAt    DateTime         @default(now())

  @@unique([businessId, citizenId])
  @@map("s6mdt_business_employee")
}

model MenuItem {
  id         String   @id @default(uuid()) @db.Char(36)
  businessId String   @db.Char(36)
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name       String
  price      Int
  category   String?

  @@map("s6mdt_menu_item")
}

model RealEstateListing {
  id         String        @id @default(uuid()) @db.Char(36)
  businessId String?       @db.Char(36)
  business   Business?     @relation(fields: [businessId], references: [id])
  propertyId String        @db.Char(36)
  property   Property      @relation(fields: [propertyId], references: [id])
  price      Int
  status     ListingStatus @default(AVAILABLE)
  agentId    String?       @db.Char(36)
  createdAt  DateTime      @default(now())

  @@index([status])
  @@map("s6mdt_real_estate_listing")
}

model MechanicJob {
  id          String    @id @default(uuid()) @db.Char(36)
  businessId  String    @db.Char(36)
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  vehicleId   String?   @db.Char(36)
  vehicle     Vehicle?  @relation(fields: [vehicleId], references: [id])
  description String    @db.Text
  cost        Int       @default(0)
  status      JobStatus @default(OPEN)
  createdAt   DateTime  @default(now())

  @@index([businessId, status])
  @@map("s6mdt_mechanic_job")
}

model SecurityContract {
  id         String   @id @default(uuid()) @db.Char(36)
  businessId String   @db.Char(36)
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  clientName String
  details    String?  @db.Text
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@map("s6mdt_security_contract")
}

model NewsArticle {
  id          String        @id @default(uuid()) @db.Char(36)
  businessId  String?       @db.Char(36)
  business    Business?     @relation(fields: [businessId], references: [id])
  authorId    String        @db.Char(36)
  title       String
  body        String        @db.Text
  status      ArticleStatus @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime      @default(now())

  @@index([status])
  @@map("s6mdt_news_article")
}

// ============================================================
//  DISPATCH / CAD
// ============================================================

model DispatchCall {
  id          String           @id @default(uuid()) @db.Char(36)
  number      Int              @unique @default(autoincrement())
  line        EmergencyLine
  callerName  String?
  location    String           @db.Text
  postal      String?
  category    String
  description String           @db.Text
  priority    DispatchPriority @default(P3)
  status      DispatchStatus   @default(OFFEN)
  sectorId    String?          @db.Char(36)
  sector      Sector?          @relation(fields: [sectorId], references: [id])
  alertKind   String? // PANIC | BACKUP (in-game-Alarm), sonst null
  officerId   String?          @db.Char(36) // auslösender Beamter (bei Panic/Backup)
  x           Float?
  y           Float?
  createdAt   DateTime         @default(now())
  closedAt    DateTime?

  assignments UnitAssignment[]
  notes       CallNote[]

  @@index([status, priority])
  @@map("s6mdt_dispatch_call")
}

model CallNote {
  id       String       @id @default(uuid()) @db.Char(36)
  callId   String       @db.Char(36)
  call     DispatchCall @relation(fields: [callId], references: [id], onDelete: Cascade)
  byUserId String       @db.Char(36)
  note     String       @db.Text
  at       DateTime     @default(now())

  @@index([callId, at])
  @@map("s6mdt_call_note")
}

model Sector {
  id        String   @id @default(uuid()) @db.Char(36)
  code      String   @unique
  name      String
  polygon   Json?
  createdAt DateTime @default(now())

  units Unit[]
  calls DispatchCall[]

  @@map("s6mdt_sector")
}

model StatusCode {
  id       String  @id @default(uuid()) @db.Char(36)
  code     String  @unique
  label    String
  category String?

  @@map("s6mdt_status_code")
}

model Unit {
  id         String     @id @default(uuid()) @db.Char(36)
  callsign   String
  factionId  String     @db.Char(36)
  faction    Faction    @relation(fields: [factionId], references: [id])
  channel    String?
  sectorId   String?    @db.Char(36)
  sector     Sector?    @relation(fields: [sectorId], references: [id])
  status     UnitStatus @default(AUSSER_DIENST)
  x          Float?
  y          Float?
  heading    Float?
  zone       String? // lesbarer Zonen-/Straßenname (aus FiveM, client-ermittelt)
  lastSeenAt DateTime?
  createdAt  DateTime   @default(now())

  members     UnitMember[]
  assignments UnitAssignment[]

  @@index([factionId, status])
  @@map("s6mdt_unit")
}

// Funkkanäle (Radio). Koordination im Web + best-effort Voice-Sync in-game.
model RadioChannel {
  id        String   @id @default(uuid()) @db.Char(36)
  name      String   @unique // Kanalkürzel, z. B. "1" / "TAC" / "DISP"
  label     String // Anzeigename
  factionId String?  @db.Char(36) // optional fraktionsgebunden (denorm., keine FK)
  isPrivate Boolean  @default(false)
  createdAt DateTime @default(now())

  members RadioMember[]

  @@map("s6mdt_radio_channel")
}

model RadioMember {
  id        String       @id @default(uuid()) @db.Char(36)
  channelId String       @db.Char(36)
  channel   RadioChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId    String       @db.Char(36)
  callsign  String? // Anzeige im Roster (denorm.)
  joinedAt  DateTime     @default(now())

  @@unique([channelId, userId])
  @@index([userId])
  @@map("s6mdt_radio_member")
}

model UnitMember {
  id     String  @id @default(uuid()) @db.Char(36)
  unitId String  @db.Char(36)
  unit   Unit    @relation(fields: [unitId], references: [id], onDelete: Cascade)
  userId String  @db.Char(36)
  isLead Boolean @default(false)

  @@unique([unitId, userId])
  @@map("s6mdt_unit_member")
}

model UnitAssignment {
  id         String       @id @default(uuid()) @db.Char(36)
  callId     String       @db.Char(36)
  call       DispatchCall @relation(fields: [callId], references: [id], onDelete: Cascade)
  unitId     String       @db.Char(36)
  unit       Unit         @relation(fields: [unitId], references: [id], onDelete: Cascade)
  assignedAt DateTime     @default(now())
  clearedAt  DateTime?

  @@unique([callId, unitId])
  @@map("s6mdt_unit_assignment")
}

// ============================================================
//  WORKFORCE
// ============================================================

model ShiftLog {
  id          String    @id @default(uuid()) @db.Char(36)
  userId      String    @db.Char(36)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  factionId   String    @db.Char(36)
  rankName    String?
  shiftType   ShiftType @default(FRUEH)
  startedAt   DateTime  @default(now())
  endedAt     DateTime?
  durationSec Int?
  autoClosed  Boolean   @default(false)

  @@index([userId, startedAt])
  @@index([factionId, startedAt])
  @@map("s6mdt_shift_log")
}

model ShiftSchedule {
  id        String    @id @default(uuid()) @db.Char(36)
  factionId String    @db.Char(36)
  faction   Faction   @relation(fields: [factionId], references: [id], onDelete: Cascade)
  shiftType ShiftType
  startsAt  DateTime
  endsAt    DateTime
  recurring String?
  createdAt DateTime  @default(now())

  assignments ShiftAssignment[]

  @@index([factionId, startsAt])
  @@map("s6mdt_shift_schedule")
}

model ShiftAssignment {
  id         String        @id @default(uuid()) @db.Char(36)
  scheduleId String        @db.Char(36)
  schedule   ShiftSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  userId     String        @db.Char(36)
  isStandIn  Boolean       @default(false)

  @@unique([scheduleId, userId])
  @@map("s6mdt_shift_assignment")
}

model LeaveRequest {
  id          String      @id @default(uuid()) @db.Char(36)
  userId      String      @db.Char(36)
  factionId   String      @db.Char(36)
  type        LeaveType
  status      LeaveStatus @default(REQUESTED)
  fromDate    DateTime
  toDate      DateTime
  reason      String?     @db.Text
  decidedById String?     @db.Char(36)
  createdAt   DateTime    @default(now())

  @@index([userId, status])
  @@map("s6mdt_leave_request")
}

// ============================================================
//  WORKFLOW ENGINE
// ============================================================

model WorkflowDefinition {
  id            String        @id @default(uuid()) @db.Char(36)
  key           String        @unique
  name          String
  appliesToType CaseFileType?
  factionId     String?       @db.Char(36)
  createdAt     DateTime      @default(now())

  states      WorkflowState[]
  transitions WorkflowTransition[]
  instances   WorkflowInstance[]

  @@map("s6mdt_workflow_definition")
}

model WorkflowState {
  id           String             @id @default(uuid()) @db.Char(36)
  definitionId String             @db.Char(36)
  definition   WorkflowDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  key          String
  name         String
  isInitial    Boolean            @default(false)
  isFinal      Boolean            @default(false)

  transitionsFrom WorkflowTransition[] @relation("TransitionFrom")
  transitionsTo   WorkflowTransition[] @relation("TransitionTo")
  instances       WorkflowInstance[]

  @@unique([definitionId, key])
  @@map("s6mdt_workflow_state")
}

model WorkflowTransition {
  id           String             @id @default(uuid()) @db.Char(36)
  definitionId String             @db.Char(36)
  definition   WorkflowDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  name         String
  fromStateId  String             @db.Char(36)
  fromState    WorkflowState      @relation("TransitionFrom", fields: [fromStateId], references: [id])
  toStateId    String             @db.Char(36)
  toState      WorkflowState      @relation("TransitionTo", fields: [toStateId], references: [id])
  allowedRoles Json?

  @@index([definitionId])
  @@map("s6mdt_workflow_transition")
}

model WorkflowInstance {
  id             String             @id @default(uuid()) @db.Char(36)
  definitionId   String             @db.Char(36)
  definition     WorkflowDefinition @relation(fields: [definitionId], references: [id])
  caseFileId     String?            @db.Char(36)
  caseFile       CaseFile?          @relation(fields: [caseFileId], references: [id])
  currentStateId String             @db.Char(36)
  currentState   WorkflowState      @relation(fields: [currentStateId], references: [id])
  status         WorkflowStatus     @default(ACTIVE)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  tasks WorkflowTask[]

  @@index([status])
  @@index([caseFileId])
  @@map("s6mdt_workflow_instance")
}

model WorkflowTask {
  id             String           @id @default(uuid()) @db.Char(36)
  instanceId     String           @db.Char(36)
  instance       WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  title          String
  assigneeUserId String?          @db.Char(36)
  status         TaskStatus       @default(TODO)
  dueAt          DateTime?
  createdAt      DateTime         @default(now())

  @@index([instanceId, status])
  @@map("s6mdt_workflow_task")
}

// ============================================================
//  DOKUMENTE / SIGNATUREN
// ============================================================

model Document {
  id           String    @id @default(uuid()) @db.Char(36)
  caseFileId   String?   @db.Char(36)
  caseFile     CaseFile? @relation(fields: [caseFileId], references: [id], onDelete: SetNull)
  filename     String
  mimeType     String
  storageRef   String    @db.Text
  size         Int
  version      Int       @default(1)
  uploadedById String    @db.Char(36)
  createdAt    DateTime  @default(now())

  versions DocumentVersion[]

  @@index([caseFileId])
  @@map("s6mdt_document")
}

model DocumentVersion {
  id           String   @id @default(uuid()) @db.Char(36)
  documentId   String   @db.Char(36)
  document     Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  version      Int
  storageRef   String   @db.Text
  size         Int
  uploadedById String   @db.Char(36)
  createdAt    DateTime @default(now())

  @@unique([documentId, version])
  @@map("s6mdt_document_version")
}

model Signature {
  id          String   @id @default(uuid()) @db.Char(36)
  caseFileId  String   @db.Char(36)
  caseFile    CaseFile @relation(fields: [caseFileId], references: [id], onDelete: Cascade)
  signerId    String   @db.Char(36)
  signer      User     @relation(fields: [signerId], references: [id])
  payloadHash String
  signedAt    DateTime @default(now())

  @@index([caseFileId])
  @@map("s6mdt_signature")
}

// ============================================================
//  PLATFORM: Benachrichtigungen + Audit
// ============================================================

model Notification {
  id      String           @id @default(uuid()) @db.Char(36)
  userId  String           @db.Char(36)
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type    NotificationType @default(INFO)
  title   String
  body    String?          @db.Text
  read    Boolean          @default(false)
  refType String?
  refId   String?
  at      DateTime         @default(now())

  @@index([userId, read])
  @@map("s6mdt_notification")
}

// ============================================================
//  PHASE 7: Chat, Settings, Tags
// ============================================================

// Interner Behörden-Chat (LEO-Chat). Kanal = "GLOBAL" oder Fraktions-ID.
model ChatMessage {
  id         String   @id @default(uuid()) @db.Char(36)
  channel    String // "GLOBAL" oder factionId
  senderId   String   @db.Char(36)
  senderName String // denorm. Anzeigename/Callsign
  body       String   @db.Text
  createdAt  DateTime @default(now())

  @@index([channel, createdAt])
  @@map("s6mdt_chat_message")
}

// Persönliche Einstellungen je Nutzer.
model UserSettings {
  id             String   @id @default(uuid()) @db.Char(36)
  userId         String   @unique @db.Char(36)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme          String   @default("system") // system | light | dark
  notifyDispatch Boolean  @default(true)
  notifyChat     Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("s6mdt_user_settings")
}

// Tags/Flags (z. B. "Bewaffnet", "Informant", "Gangmitglied").
model Tag {
  id        String   @id @default(uuid()) @db.Char(36)
  name      String
  color     String   @default("gray") // Badge-Ton
  category  String?
  factionId String?  @db.Char(36) // optional fraktionsgebunden (denorm., keine FK)
  createdAt DateTime @default(now())

  citizenTags CitizenTag[]

  @@unique([name, factionId])
  @@map("s6mdt_tag")
}

model CitizenTag {
  id        String   @id @default(uuid()) @db.Char(36)
  citizenId String   @db.Char(36)
  citizen   Citizen  @relation(fields: [citizenId], references: [id], onDelete: Cascade)
  tagId     String   @db.Char(36)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  byUserId  String?  @db.Char(36)
  createdAt DateTime @default(now())

  @@unique([citizenId, tagId])
  @@index([citizenId])
  @@map("s6mdt_citizen_tag")
}

model AuditLog {
  id          String      @id @default(uuid()) @db.Char(36)
  userId      String?     @db.Char(36)
  user        User?       @relation(fields: [userId], references: [id])
  factionId   String?     @db.Char(36)
  rankName    String?
  action      AuditAction
  subjectType String
  subjectId   String?
  before      Json?
  after       Json?
  ip          String?
  userAgent   String?     @db.Text
  at          DateTime    @default(now())
  prevHash    String?
  hash        String

  @@index([subjectType, subjectId])
  @@index([userId, at])
  @@map("s6mdt_audit_log")
}
