{
  "name": "aktensystem-fivem",
  "version": "0.1.0",
  "private": true,
  "description": "Enterprise RMS/CAD/DMS/Case-Management Plattform für FiveM Roleplay",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "pnpm --filter @aktensystem/database prisma generate",
    "db:migrate": "pnpm --filter @aktensystem/database prisma migrate dev",
    "db:seed": "pnpm --filter @aktensystem/database db:seed",
    "db:studio": "pnpm --filter @aktensystem/database prisma studio"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.5.0",
    "typescript": "^5.7.3"
  }
}
