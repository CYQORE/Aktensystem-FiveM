# ============================================================
# S6mdt — Deploy-Konfiguration. Nach .env kopieren und ausfüllen.
# ============================================================
NODE_ENV=production

# --- Datenbank: bestehende FiveM-MySQL ---
# MySQL läuft auf dem Host? -> host.docker.internal benutzen (Container -> Host).
# Beispiel passend zu deiner server.cfg (DB ESXLegacy_E28CCE, root ohne Passwort):
DATABASE_URL="mysql://root@host.docker.internal:3306/ESXLegacy_E28CCE"

# --- Redis (läuft im Compose) ---
REDIS_URL="redis://redis:6379"

# --- Secrets (PFLICHT in Produktion — keine Defaults!) ---
JWT_SECRET="HIER_LANGES_ZUFALLS_SECRET_MIN_32_ZEICHEN"
JWT_REFRESH_SECRET="HIER_ANDERES_LANGES_ZUFALLS_SECRET_32"
FIVEM_BRIDGE_TOKEN="HIER_SHARED_SECRET_FUER_LUA_BRIDGE"

# --- Discord OAuth (optional, nur Admin-Fallback-Login) ---
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
DISCORD_CALLBACK_URL="http://DEINE_DOMAIN_ODER_IP:4000/api/v1/auth/discord/callback"

# --- URLs / CORS ---
# Domain/IP des Servers (von außen erreichbar).
WEB_ORIGIN="http://DEINE_DOMAIN_ODER_IP:3000"
NEXT_PUBLIC_API_URL="http://DEINE_DOMAIN_ODER_IP:4000/api/v1"
NEXT_PUBLIC_WS_URL="http://DEINE_DOMAIN_ODER_IP:4000"

# --- MinIO (Objekt-Storage, läuft im Compose) ---
MINIO_ENDPOINT="minio"
MINIO_PORT="9000"
MINIO_USE_SSL="false"
MINIO_ACCESS_KEY="s6mdt_minio_admin"
MINIO_SECRET_KEY="HIER_MINIO_PASSWORT_AENDERN"
MINIO_BUCKET="s6mdt-documents"

# --- Ports ---
API_PORT="4000"
WEB_PORT="3000"
