# ============================================================
# S6mdt — Deploy-Konfiguration. Nach .env kopieren und ausfüllen.
# (Self-contained Setup: eigene MariaDB ist im docker-compose enthalten.)
# ============================================================
NODE_ENV=production

# --- Datenbank ---
# Standard: mitgelieferte MariaDB (nur Root-Passwort setzen).
DB_ROOT_PASSWORD=HIER_DB_PASSWORT_AENDERN
#
# ODER direkt auf der FiveM-Game-DB laufen (für Server-Sync: Spieler + Fahrzeuge).
# Dann DATABASE_URL setzen — überschreibt die mitgelieferte MariaDB. Die Game-DB
# muss vom API-Container erreichbar sein (Host/Port offen + DB-User mit Rechten).
# Danach einmal `db:push` (legt s6mdt_*-Tabellen neben den ESX-Tabellen an).
# DATABASE_URL=mysql://USER:PASSWORT@GAME_DB_HOST:3306/esxlegacy_e28cce

# --- Secrets (PFLICHT — keine Defaults in Produktion!) ---
# Tipp: jeweils mit `openssl rand -hex 32` erzeugen.
JWT_SECRET=HIER_LANGES_ZUFALLS_SECRET_MIN_32_ZEICHEN
JWT_REFRESH_SECRET=HIER_ANDERES_LANGES_ZUFALLS_SECRET_32
FIVEM_BRIDGE_TOKEN=HIER_SHARED_SECRET_FUER_LUA_BRIDGE

# --- Discord OAuth (optional, nur Admin-Fallback-Login) ---
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_CALLBACK_URL=https://cad.cyqore.app/api/v1/auth/discord/callback

# --- URLs / CORS (HTTPS-Domain via Caddy) ---
WEB_ORIGIN=https://cad.cyqore.app
NEXT_PUBLIC_API_URL=https://cad.cyqore.app/api/v1
NEXT_PUBLIC_WS_URL=https://cad.cyqore.app

# --- MinIO (Objekt-Storage, im Compose) ---
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=s6mdt_minio_admin
MINIO_SECRET_KEY=HIER_MINIO_PASSWORT_AENDERN
MINIO_BUCKET=s6mdt-documents

# --- Ports ---
API_PORT=4000
WEB_PORT=3000
